rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user has admin role
    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.role == 'admin';
    }
    
    // Helper function to check if user has salesman role
    function isSalesman() {
      return isAuthenticated() && 
             request.auth.token.role == 'salesman';
    }
    
    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && 
             request.auth.uid == userId;
    }
    
    // Users collection - role-based access
    match /users/{userId} {
      // Admins can read/write all user documents
      // Salesmen can only read/write their own document
      allow read, write: if isAdmin() || isOwner(userId);
      
      // Validate user data structure on write
      allow write: if isAuthenticated() && 
                      validateUserData(request.resource.data);
    }
    
    // Location history collection
    match /location_history/{locationId} {
      // Admins can read all location history
      // Salesmen can only read their own location history
      allow read: if isAdmin() || 
                     (isSalesman() && isOwner(resource.data.user_id));
      
      // Only salesmen can write their own location data
      allow write: if isSalesman() && 
                      isOwner(request.resource.data.user_id) &&
                      validateLocationData(request.resource.data);
    }
    
    // Daily distance collection
    match /daily_distance/{distanceId} {
      // Admins can read all daily distance records
      // Salesmen can only read their own records
      allow read: if isAdmin() || 
                     (isSalesman() && isOwner(resource.data.user_id));
      
      // Only salesmen can write their own distance data
      allow write: if isSalesman() && 
                      isOwner(request.resource.data.user_id) &&
                      validateDistanceData(request.resource.data);
    }
    
    // Validation functions
    function validateUserData(data) {
      return data.keys().hasAll(['email', 'role', 'name', 'active', 'created_at']) &&
             data.email is string &&
             data.role in ['admin', 'salesman'] &&
             data.name is string &&
             data.active is bool &&
             data.created_at is timestamp;
    }
    
    function validateLocationData(data) {
      return data.keys().hasAll(['user_id', 'latitude', 'longitude', 'timestamp', 'accuracy']) &&
             data.user_id is string &&
             data.latitude is number &&
             data.longitude is number &&
             data.timestamp is timestamp &&
             data.accuracy is number &&
             data.latitude >= -90 && data.latitude <= 90 &&
             data.longitude >= -180 && data.longitude <= 180;
    }
    
    function validateDistanceData(data) {
      return data.keys().hasAll(['user_id', 'date', 'total_distance', 'start_time', 'end_time']) &&
             data.user_id is string &&
             data.date is string &&
             data.total_distance is number &&
             data.start_time is timestamp &&
             data.end_time is timestamp &&
             data.total_distance >= 0;
    }
  }
}