{
    "rules": {
        "live_locations": {
            "$userId": {
                ".read": "auth != null && (auth.token.role == 'admin' || auth.uid == $userId)",
                ".write": "auth != null && auth.uid == $userId && auth.token.role == 'salesman'",
                ".validate": "newData.hasChildren(['latitude', 'longitude', 'timestamp', 'accuracy', 'is_active'])",
                "latitude": {
                    ".validate": "newData.isNumber() && newData.val() >= -90 && newData.val() <= 90"
                },
                "longitude": {
                    ".validate": "newData.isNumber() && newData.val() >= -180 && newData.val() <= 180"
                },
                "timestamp": {
                    ".validate": "newData.isNumber()"
                },
                "accuracy": {
                    ".validate": "newData.isNumber() && newData.val() >= 0"
                },
                "speed": {
                    ".validate": "newData.isNumber() && newData.val() >= 0"
                },
                "heading": {
                    ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 360"
                },
                "is_active": {
                    ".validate": "newData.isBoolean()"
                }
            }
        }
    }
}