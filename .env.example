# =============================================================================
# ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env files to version control
# =============================================================================

# =============================================================================
# GOOGLE CLOUD / FIREBASE AUTHENTICATION
# =============================================================================

# Option 1: Use service account JSON content directly (recommended for production)
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"your-project",...}'

# Option 2: Use path to service account file (recommended for development)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account.json

# Firebase Project Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_API_KEY=your-firebase-api-key

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Environment type (development, staging, production)
ENVIRONMENT=development

# Debug mode (true/false)
DEBUG_MODE=true

# =============================================================================
# API CONFIGURATION
# =============================================================================

# Backend API URL
API_BASE_URL=http://localhost:3000

# External API Keys (if needed)
# EXTERNAL_API_KEY=your-external-api-key
# MAPBOX_ACCESS_TOKEN=your-mapbox-token

# =============================================================================
# DATABASE CONFIGURATION (if applicable)
# =============================================================================

# DATABASE_URL=your-database-connection-string

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# JWT Secret (generate a secure random string)
# JWT_SECRET=your-jwt-secret-key

# Encryption keys (generate secure random strings)
# ENCRYPTION_KEY=your-encryption-key

# =============================================================================
# DEVELOPMENT TOOLS
# =============================================================================

# Enable/disable development features
# ENABLE_LOGGING=true
# ENABLE_DEBUGGING=true

# =============================================================================
# INSTRUCTIONS
# =============================================================================
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual values (remove the # comments)
# 3. Never commit .env files to version control
# 4. For production, use environment variables or secure secret management
# 5. See docs/CREDENTIAL_SETUP.md for detailed setup instructions