generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Country {
  country_id    Int            @id @default(autoincrement())
  country_name  String         @db.VarChar(100)
  employeeAreas EmployeeArea[]
  states        State[]
}

model State {
  state_id      Int            @id @default(autoincrement())
  state_name    String         @db.VarChar(100)
  country_id    Int
  employeeAreas EmployeeArea[]
  regions       Region[]
  country       Country        @relation(fields: [country_id], references: [country_id], onDelete: Cascade)
}

model Region {
  region_id     Int            @id @default(autoincrement())
  region_name   String         @db.VarChar(100)
  state_id      Int
  districts     District[]
  employeeAreas EmployeeArea[]
  state         State          @relation(fields: [state_id], references: [state_id], onDelete: Cascade)
}

model District {
  district_id   Int            @id @default(autoincrement())
  district_name String         @db.VarChar(100)
  region_id     Int
  cities        City[]
  region        Region         @relation(fields: [region_id], references: [region_id], onDelete: Cascade)
  employeeAreas EmployeeArea[]
}

model City {
  city_id       Int            @id @default(autoincrement())
  city_name     String         @db.VarChar(100)
  district_id   Int
  district      District       @relation(fields: [district_id], references: [district_id], onDelete: Cascade)
  employeeAreas EmployeeArea[]
  zones         Zone[]
}

model Zone {
  zone_id       Int            @id @default(autoincrement())
  zone_name     String         @db.VarChar(100)
  city_id       Int
  areas         Area[]
  employeeAreas EmployeeArea[]
  city          City           @relation(fields: [city_id], references: [city_id], onDelete: Cascade)
}

model Area {
  area_id       Int            @id @default(autoincrement())
  area_name     String         @db.VarChar(100)
  zone_id       Int
  accounts      Account[]
  zone          Zone           @relation(fields: [zone_id], references: [zone_id], onDelete: Cascade)
  employeeAreas EmployeeArea[]
}

model Department {
  id        String   @id
  name      String   @unique
  createdAt DateTime @default(now())
  users     User[]
}

model Role {
  id        String   @id
  name      String
  createdAt DateTime @default(now())
  users     User[]
}

model User {
  id                 String        @id
  employeeCode       String?       @unique
  name               String?
  email              String?       @unique
  contactNumber      String        @unique
  alternativeNumber  String?
  roleId             String?
  roles              String[]      @default([])
  departmentId       String?
  otp                String?
  otpExpiry          DateTime?
  lastLogin          DateTime?
  isActive           Boolean       @default(true)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  dateOfBirth        DateTime?
  gender             String?
  image              String?
  preferredLanguages String[]
  address            String?
  city               String?
  state              String?
  pincode            String?
  country            String?
  district           String?
  area               String?
  latitude           Float?
  longitude          Float?
  aadharCard         String?
  panCard            String?
  password           String?
  notes              String?
  
  // Working Hours Configuration (added via migration - DO NOT UNCOMMENT until migration is run)
  workStartTime              String?   @default("09:00:00") // Work start time (HH:MM:SS format)
  workEndTime                String?   @default("18:00:00") // Work end time (HH:MM:SS format)
  latePunchInGraceMinutes    Int?      @default(45)         // Minutes after work start time before requiring approval
  earlyPunchOutGraceMinutes  Int?      @default(30)         // Minutes before work end time that require approval
  
  assignedAccounts   Account[]           @relation("AccountAssignedTo")
  createdAccounts    Account[]           @relation("AccountCreatedBy")
  approvedAccounts   Account[]           @relation("AccountApprovedBy")
  employeeArea       EmployeeArea?
  salaryInformation  SalaryInformation?
  expenses           Expense[]           @relation("EmployeeExpenses")
  approvedExpenses   Expense[]           @relation("ApprovedExpenses")
  department         Department?         @relation(fields: [departmentId], references: [id])
  role               Role?               @relation(fields: [roleId], references: [id])
  areaAssignments    AreaAssignment[]
  routeLogs          SalesmanRouteLog[]  // Route tracking logs for this salesman
  notifications      Notification[]      // Notifications targeted to this user
  lateApprovalRequests LatePunchApproval[] @relation("EmployeeLateApprovals") // Late punch-in requests by this employee
  approvedLateRequests LatePunchApproval[] @relation("AdminLateApprovals") // Late punch-in requests approved by this admin
  earlyPunchOutRequests EarlyPunchOutApproval[] @relation("EmployeeEarlyPunchOutApprovals") // Early punch-out requests by this employee
  approvedEarlyPunchOutRequests EarlyPunchOutApproval[] @relation("AdminEarlyPunchOutApprovals") // Early punch-out requests approved by this admin
  leaveRequests Leave[] @relation("EmployeeLeaves") // Leave requests by this employee
  approvedLeaves Leave[] @relation("ApprovedLeaves") // Leave requests approved by this admin
  leaveBalance LeaveBalance? // Leave balance for this employee
}

model EmployeeArea {
  area_id     Int?
  city_id     Int?
  country_id  Int?
  district_id Int?
  employeeId  String    @unique
  latitude    Float?
  longitude   Float?
  region_id   Int?
  state_id    Int?
  zone_id     Int?
  id          Int       @id @default(autoincrement())
  area        Area?     @relation(fields: [area_id], references: [area_id])
  city        City?     @relation(fields: [city_id], references: [city_id])
  country     Country?  @relation(fields: [country_id], references: [country_id])
  district    District? @relation(fields: [district_id], references: [district_id])
  employee    User      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  region      Region?   @relation(fields: [region_id], references: [region_id])
  state       State?    @relation(fields: [state_id], references: [state_id])
  zone        Zone?     @relation(fields: [zone_id], references: [zone_id])
}

model Account {
  id                    String    @id
  accountCode           String    @unique
  businessName          String?   // Made optional to handle existing data
  businessType          String?
  businessSize          String?   // New field: Semi Retailer, Retailer, Semi Wholesaler, Wholesaler, Home Buyer
  personName            String
  contactNumber         String
  dateOfBirth           DateTime?
  customerStage         String?
  funnelStage           String?
  gstNumber             String?
  panCard               String?
  ownerImage            String?   // URL to business owner personal image
  shopImage             String?   // URL to shop image
  isActive              Boolean   @default(true)
  
  // Location fields (pincode-based)
  pincode               String?
  country               String?
  state                 String?
  district              String?
  city                  String?
  area                  String?
  address               String?   // Manual address field
  latitude              Float?    // Geolocation latitude
  longitude             Float?    // Geolocation longitude
  
  // Legacy area relation (kept for backward compatibility)
  areaId                Int?
  
  // Assignment and approval
  assignedToId          String?
  createdById           String?
  approvedById          String?
  approvedAt            DateTime?
  isApproved            Boolean   @default(false)
  
  // Timestamps
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  // Relations
  areaRelation          Area?     @relation(fields: [areaId], references: [area_id])
  assignedTo            User?     @relation("AccountAssignedTo", fields: [assignedToId], references: [id])
  createdBy             User?     @relation("AccountCreatedBy", fields: [createdById], references: [id])
  approvedBy            User?     @relation("AccountApprovedBy", fields: [approvedById], references: [id])
  
  @@index([pincode])
  @@index([isActive])
  @@index([customerStage])
  @@index([createdAt])
  @@index([businessType])
  @@index([businessSize])
}

model SalaryInformation {
  id                    String    @id @default(cuid())
  employeeId            String    @unique
  basicSalary           Float
  hra                   Float?    @default(0)
  travelAllowance       Float?    @default(0)
  dailyAllowance        Float?    @default(0)
  medicalAllowance      Float?    @default(0)
  specialAllowance      Float?    @default(0)
  otherAllowances       Float?    @default(0)
  providentFund         Float?    @default(0)
  professionalTax       Float?    @default(0)
  incomeTax             Float?    @default(0)
  otherDeductions       Float?    @default(0)
  effectiveFrom         DateTime
  effectiveTo           DateTime?
  currency              String    @default("INR")
  paymentFrequency      String    @default("Monthly")
  bankName              String?
  accountNumber         String?
  ifscCode              String?
  panNumber             String?
  remarks               String?
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  employee              User      @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([effectiveFrom])
  @@index([isActive])
}

model Expense {
  id              String    @id @default(cuid())
  employeeId      String
  expenseType     String    // Travel, Food, Accommodation, Fuel, Other
  amount          Float
  expenseDate     DateTime
  description     String?
  billNumber      String?
  attachmentUrl   String?   // For bill/receipt image
  status          String    @default("Pending") // Pending, Approved, Rejected, Paid
  approvedBy      String?
  approvedAt      DateTime?
  rejectionReason String?
  paidAt          DateTime?
  remarks         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  employee        User      @relation("EmployeeExpenses", fields: [employeeId], references: [id], onDelete: Cascade)
  approver        User?     @relation("ApprovedExpenses", fields: [approvedBy], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([expenseDate])
  @@index([expenseType])
}

model TaskAssignment {
  id              String    @id @default(cuid())
  salesmanId      String
  salesmanName    String
  pincode         String
  country         String?
  state           String?
  district        String?
  city            String?
  areas           String[]  // Array of area names
  businessTypes   String[]  // Array of business types: grocery, cafe, hotel, etc.
  totalBusinesses Int?      @default(0)
  assignedDate    DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([salesmanId])
  @@index([pincode])
  @@index([assignedDate])
}

model Shop {
  id              String    @id @default(cuid())
  placeId         String?   @unique // Google Places ID
  name            String
  businessType    String    // grocery, cafe, hotel, dairy, restaurant, bakery, pharmacy, supermarket, others
  address         String?
  pincode         String
  area            String?
  city            String?
  state           String?
  country         String?
  latitude        Float?
  longitude       Float?
  phoneNumber     String?
  rating          Float?
  stage           String    @default("new") // new, follow-up, converted, lost
  assignedTo      String?   // Salesman ID
  notes           String?
  lastContactDate DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([pincode])
  @@index([businessType])
  @@index([stage])
  @@index([assignedTo])
  @@index([area])
}

model Attendance {
  id                  String    @id @default(cuid())
  employeeId          String
  employeeName        String
  date                DateTime  @default(now())
  
  // Punch In Details
  punchInTime         DateTime
  punchInLatitude     Float
  punchInLongitude    Float
  punchInPhoto        String?   // Base64 or URL
  punchInAddress      String?
  bikeKmStart         String?   // Starting bike odometer reading
  
  // Punch Out Details
  punchOutTime        DateTime?
  punchOutLatitude    Float?
  punchOutLongitude   Float?
  punchOutPhoto       String?   // Base64 or URL
  punchOutAddress     String?
  bikeKmEnd           String?   // Ending bike odometer reading
  
  // Calculated Fields
  totalWorkHours      Float?    // In hours
  totalDistanceKm     Float?    // Distance between punch in and punch out
  status              String    @default("active") // active, completed
  
  // Late Punch-In Approval Fields
  isLatePunchIn       Boolean   @default(false) // Whether this was a late punch-in
  lateApprovalId      String?   // Reference to the approval request
  approvalCode        String?   // The code used for late punch-in
  
  // Early Punch-Out Approval Fields
  isEarlyPunchOut     Boolean   @default(false) // Whether this was an early punch-out
  earlyPunchOutApprovalId String? // Reference to the early punch-out approval request
  earlyPunchOutCode   String?   // The code used for early punch-out
  
  // Metadata
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  // Relations
  routeLogs           SalesmanRouteLog[]  // GPS route points for this attendance session
  
  @@index([employeeId])
  @@index([date])
  @@index([status])
  @@index([punchInTime])
  @@index([isLatePunchIn])
}

model AreaAssignment {
  id              String    @id @default(cuid())
  salesmanId      String
  pinCode         String
  country         String
  state           String
  district        String
  city            String
  areas           String[]  // Array of area names
  businessTypes   String[]  // Array of business types to focus on
  assignedDate    DateTime  @default(now())
  totalBusinesses Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  salesman        User      @relation(fields: [salesmanId], references: [id], onDelete: Cascade)

  @@index([salesmanId])
  @@index([pinCode])
  @@index([city, district])
}

// NEW MODEL: Salesman Route Tracking
// This model stores GPS points during active attendance sessions
// for route visualization and playback in Admin dashboard
model SalesmanRouteLog {
  id             String   @id @default(cuid())
  employeeId     String   // Reference to User (salesman)
  attendanceId   String   // Reference to Attendance session
  latitude       Float    // GPS latitude coordinate
  longitude      Float    // GPS longitude coordinate
  speed          Float?   // Optional: Speed in km/h if available
  accuracy       Float?   // Optional: GPS accuracy in meters
  isHomeLocation Boolean  @default(false) // Mark if this is the home/starting location
  recordedAt     DateTime @default(now()) // Timestamp when GPS point was recorded
  
  // Relations
  employee       User       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  attendance     Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  
  // Indexes for performance optimization
  @@index([employeeId])     // Query routes by salesman
  @@index([attendanceId])   // Query routes by attendance session
  @@index([recordedAt])     // Query routes by time for chronological ordering
  @@index([isHomeLocation]) // Query home locations
}

model Notification {
  id          String    @id @default(cuid())
  title       String
  message     String
  type        String    // punch_in, punch_out, general, alert, late_punch_approval
  priority    String    @default("normal") // low, normal, high, urgent
  targetRole  String?   // admin, salesman, telecaller, etc. (null means all)
  targetUserId String?  // specific user (null means all users with targetRole)
  data        Json?     // additional data (attendance info, etc.)
  isRead      Boolean   @default(false)
  readAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Relations
  targetUser  User?     @relation(fields: [targetUserId], references: [id], onDelete: Cascade)
  
  @@index([targetRole])
  @@index([targetUserId])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
}

// NEW MODEL: Late Punch-In Approval Requests
model LatePunchApproval {
  id              String    @id @default(cuid())
  employeeId      String    // Salesman requesting approval
  employeeName    String    // Salesman name for easy reference
  requestDate     DateTime  @default(now()) // Date of the request
  punchInDate     DateTime  // Intended punch-in date
  reason          String    // Reason for late punch-in
  status          String    @default("PENDING") // PENDING, APPROVED, REJECTED
  
  // Admin response
  approvedBy      String?   // Admin who approved/rejected
  approvedAt      DateTime? // When the decision was made
  adminRemarks    String?   // Admin's remarks/comments
  approvalCode    String?   // Generated OTP/code for approved requests
  codeExpiresAt   DateTime? // When the approval code expires
  codeUsed        Boolean   @default(false) // Whether the code has been used
  codeUsedAt      DateTime? // When the code was used for punch-in
  
  // Metadata
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  employee        User      @relation("EmployeeLateApprovals", fields: [employeeId], references: [id], onDelete: Cascade)
  approver        User?     @relation("AdminLateApprovals", fields: [approvedBy], references: [id])
  
  @@index([employeeId])
  @@index([status])
  @@index([requestDate])
  @@index([approvalCode])
}

// NEW MODEL: Early Punch-Out Approval Requests
model EarlyPunchOutApproval {
  id              String    @id @default(cuid())
  employeeId      String    // Salesman requesting approval
  employeeName    String    // Salesman name for easy reference
  attendanceId    String    // Current attendance session ID
  requestDate     DateTime  @default(now()) // Date of the request
  punchOutDate    DateTime  // Intended punch-out date
  reason          String    // Reason for early punch-out
  status          String    @default("PENDING") // PENDING, APPROVED, REJECTED
  
  // Admin response
  approvedBy      String?   // Admin who approved/rejected
  approvedAt      DateTime? // When the decision was made
  adminRemarks    String?   // Admin's remarks/comments
  approvalCode    String?   // Generated OTP/code for approved requests
  codeExpiresAt   DateTime? // When the approval code expires
  codeUsed        Boolean   @default(false) // Whether the code has been used
  codeUsedAt      DateTime? // When the code was used for punch-out
  
  // Metadata
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  employee        User      @relation("EmployeeEarlyPunchOutApprovals", fields: [employeeId], references: [id], onDelete: Cascade)
  approver        User?     @relation("AdminEarlyPunchOutApprovals", fields: [approvedBy], references: [id])
  
  @@index([employeeId])
  @@index([attendanceId])
  @@index([status])
  @@index([requestDate])
  @@index([approvalCode])
}

// NEW MODEL: Leave Management
model Leave {
  id              String    @id @default(cuid())
  employeeId      String    // Employee requesting leave
  employeeName    String    // Employee name for easy reference
  leaveType       String    // Sick, Casual, Earned, Unpaid, Emergency, Maternity, Paternity
  startDate       DateTime  // Leave start date
  endDate         DateTime  // Leave end date
  numberOfDays    Int       // Total number of leave days
  reason          String?   // Reason for leave
  status          String    @default("PENDING") // PENDING, APPROVED, REJECTED, CANCELLED
  
  // Approval workflow
  requestedAt     DateTime  @default(now()) // When leave was requested
  approvedBy      String?   // Admin who approved/rejected
  approvedAt      DateTime? // When the decision was made
  rejectionReason String?   // Admin's reason for rejection
  adminRemarks    String?   // Additional admin comments
  
  // Metadata
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  employee        User      @relation("EmployeeLeaves", fields: [employeeId], references: [id], onDelete: Cascade)
  approver        User?     @relation("ApprovedLeaves", fields: [approvedBy], references: [id])
  
  @@index([employeeId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@index([leaveType])
  @@index([requestedAt])
}

// NEW MODEL: Leave Balance Management
model LeaveBalance {
  id              String    @id @default(cuid())
  employeeId      String    @unique // One balance record per employee
  year            Int       // Leave balance year (e.g., 2024)
  
  // Leave allocations (annual)
  sickLeaves      Int       @default(12)    // Sick leave allocation
  casualLeaves    Int       @default(10)    // Casual leave allocation
  earnedLeaves    Int       @default(20)    // Earned leave allocation
  
  // Used leaves (current year)
  usedSickLeaves  Int       @default(0)     // Used sick leaves
  usedCasualLeaves Int      @default(0)     // Used casual leaves
  usedEarnedLeaves Int      @default(0)     // Used earned leaves
  
  // Metadata
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  employee        User      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([year])
}
