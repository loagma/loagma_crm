generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Country {
  country_id    Int            @id @default(autoincrement())
  country_name  String         @db.VarChar(100)
  employeeAreas EmployeeArea[]
  states        State[]
}

model State {
  state_id      Int            @id @default(autoincrement())
  state_name    String         @db.VarChar(100)
  country_id    Int
  employeeAreas EmployeeArea[]
  regions       Region[]
  country       Country        @relation(fields: [country_id], references: [country_id], onDelete: Cascade)

  @@index([country_id], map: "State_country_id_fkey")
}

model Region {
  region_id     Int            @id @default(autoincrement())
  region_name   String         @db.VarChar(100)
  state_id      Int
  districts     District[]
  employeeAreas EmployeeArea[]
  state         State          @relation(fields: [state_id], references: [state_id], onDelete: Cascade)

  @@index([state_id], map: "Region_state_id_fkey")
}

model District {
  district_id   Int            @id @default(autoincrement())
  district_name String         @db.VarChar(100)
  region_id     Int
  cities        City[]
  region        Region         @relation(fields: [region_id], references: [region_id], onDelete: Cascade)
  employeeAreas EmployeeArea[]

  @@index([region_id], map: "District_region_id_fkey")
}

model City {
  city_id       Int            @id @default(autoincrement())
  city_name     String         @db.VarChar(100)
  district_id   Int
  district      District       @relation(fields: [district_id], references: [district_id], onDelete: Cascade)
  employeeAreas EmployeeArea[]
  zones         Zone[]

  @@index([district_id], map: "City_district_id_fkey")
}

model Zone {
  zone_id       Int            @id @default(autoincrement())
  zone_name     String         @db.VarChar(100)
  city_id       Int
  areas         Area[]
  employeeAreas EmployeeArea[]
  city          City           @relation(fields: [city_id], references: [city_id], onDelete: Cascade)

  @@index([city_id], map: "Zone_city_id_fkey")
}

model Area {
  area_id       Int            @id @default(autoincrement())
  area_name     String         @db.VarChar(100)
  zone_id       Int
  accounts      Account[]
  zone          Zone           @relation(fields: [zone_id], references: [zone_id], onDelete: Cascade)
  employeeAreas EmployeeArea[]

  @@index([zone_id], map: "Area_zone_id_fkey")
}

model Department {
  id        String   @id
  name      String   @unique
  createdAt DateTime @default(now())
  users     User[]
}

model Role {
  id        String   @id
  name      String
  createdAt DateTime @default(now())
  users     User[]
}

model User {
  id                            String                        @id
  employeeCode                  String?                       @unique
  name                          String?
  email                         String?                       @unique
  contactNumber                 String                        @unique
  alternativeNumber             String?
  roleId                        String?
  roles                         Json?
  departmentId                  String?
  otp                           String?
  otpExpiry                     DateTime?
  lastLogin                     DateTime?
  isActive                      Boolean                       @default(true)
  createdAt                     DateTime                      @default(now())
  updatedAt                     DateTime                      @updatedAt
  dateOfBirth                   DateTime?
  gender                        String?
  image                         String?
  preferredLanguages            Json?
  address                       String?
  city                          String?
  state                         String?
  pincode                       String?
  country                       String?
  district                      String?
  area                          String?
  latitude                      Float?
  longitude                     Float?
  aadharCard                    String?
  panCard                       String?
  password                      String?
  notes                         String?
  workStartTime                 String?                       @default("09:00:00")
  workEndTime                   String?                       @default("18:00:00")
  latePunchInGraceMinutes       Int?                          @default(45)
  earlyPunchOutGraceMinutes     Int?                          @default(30)
  approvedAccounts              Account[]                     @relation("AccountApprovedBy")
  assignedAccounts              Account[]                     @relation("AccountAssignedTo")
  createdAccounts               Account[]                     @relation("AccountCreatedBy")
  areaAssignments               AreaAssignment[]
  completedBeats                BeatCompletion[]              @relation("CompletedBeats")
  verifiedBeats                 BeatCompletion[]              @relation("VerifiedBeats")
  approvedEarlyPunchOutRequests EarlyPunchOutApproval[]       @relation("AdminEarlyPunchOutApprovals")
  earlyPunchOutRequests         EarlyPunchOutApproval[]       @relation("EmployeeEarlyPunchOutApprovals")
  employeeArea                  EmployeeArea?
  approvedExpenses              Expense[]                     @relation("ApprovedExpenses")
  expenses                      Expense[]                     @relation("EmployeeExpenses")
  approvedLateRequests          LatePunchApproval[]           @relation("AdminLateApprovals")
  lateApprovalRequests          LatePunchApproval[]           @relation("EmployeeLateApprovals")
  approvedLeaves                Leave[]                       @relation("ApprovedLeaves")
  leaveRequests                 Leave[]                       @relation("EmployeeLeaves")
  leaveBalance                  LeaveBalance?
  notifications                 Notification[]
  salaryInformation             SalaryInformation?
  trackingPoints                SalesmanTrackingPoint[]       @relation("EmployeeTrackingPoints")
  telecallerLogs                TelecallerCallLog[]
  telecallerPincodeAssignments  TelecallerPincodeAssignment[] @relation("TelecallerPincodeAssignments")
  department                    Department?                   @relation(fields: [departmentId], references: [id])
  role                          Role?                         @relation(fields: [roleId], references: [id])
  approvedBeatPlans             WeeklyBeatPlan[]              @relation("ApprovedBeatPlans")
  generatedBeatPlans            WeeklyBeatPlan[]              @relation("GeneratedBeatPlans")
  lockedBeatPlans               WeeklyBeatPlan[]              @relation("LockedBeatPlans")
  salesmanBeatPlans             WeeklyBeatPlan[]              @relation("SalesmanBeatPlans")

  @@index([departmentId], map: "User_departmentId_fkey")
  @@index([roleId], map: "User_roleId_fkey")
}

model EmployeeArea {
  area_id     Int?
  city_id     Int?
  country_id  Int?
  district_id Int?
  employeeId  String    @unique
  latitude    Float?
  longitude   Float?
  region_id   Int?
  state_id    Int?
  zone_id     Int?
  id          Int       @id @default(autoincrement())
  area        Area?     @relation(fields: [area_id], references: [area_id])
  city        City?     @relation(fields: [city_id], references: [city_id])
  country     Country?  @relation(fields: [country_id], references: [country_id])
  district    District? @relation(fields: [district_id], references: [district_id])
  employee    User      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  region      Region?   @relation(fields: [region_id], references: [region_id])
  state       State?    @relation(fields: [state_id], references: [state_id])
  zone        Zone?     @relation(fields: [zone_id], references: [zone_id])

  @@index([area_id], map: "EmployeeArea_area_id_fkey")
  @@index([city_id], map: "EmployeeArea_city_id_fkey")
  @@index([country_id], map: "EmployeeArea_country_id_fkey")
  @@index([district_id], map: "EmployeeArea_district_id_fkey")
  @@index([region_id], map: "EmployeeArea_region_id_fkey")
  @@index([state_id], map: "EmployeeArea_state_id_fkey")
  @@index([zone_id], map: "EmployeeArea_zone_id_fkey")
}

model Account {
  id                String              @id
  accountCode       String              @unique
  businessName      String?
  businessType      String?
  businessSize      String?
  personName        String
  contactNumber     String
  dateOfBirth       DateTime?
  customerStage     String?
  funnelStage       String?
  gstNumber         String?
  panCard           String?
  ownerImage        String?
  shopImage         String?
  isActive          Boolean             @default(true)
  pincode           String?
  country           String?
  state             String?
  district          String?
  city              String?
  area              String?
  address           String?
  latitude          Float?
  longitude         Float?
  areaId            Int?
  assignedToId      String?
  assignedDays      Json?
  createdById       String?
  approvedById      String?
  approvedAt        DateTime?
  isApproved        Boolean             @default(false)
  verificationNotes String?
  rejectionNotes    String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  approvedBy        User?               @relation("AccountApprovedBy", fields: [approvedById], references: [id])
  areaRelation      Area?               @relation(fields: [areaId], references: [area_id])
  assignedTo        User?               @relation("AccountAssignedTo", fields: [assignedToId], references: [id])
  createdBy         User?               @relation("AccountCreatedBy", fields: [createdById], references: [id])
  callLogs          TelecallerCallLog[]
  weeklyAssignments WeeklyAccountAssignment[]

  @@index([pincode])
  @@index([isActive])
  @@index([customerStage])
  @@index([createdAt])
  @@index([businessType])
  @@index([businessSize])
  @@index([approvedById], map: "Account_approvedById_fkey")
  @@index([areaId], map: "Account_areaId_fkey")
  @@index([assignedToId], map: "Account_assignedToId_fkey")
  @@index([createdById], map: "Account_createdById_fkey")
}

model WeeklyAccountAssignment {
  id               String   @id @default(cuid())
  accountId        String
  salesmanId       String
  pincode          String
  weekStartDate    DateTime
  assignedDays     Json
  visitFrequency   String?
  recurrenceAfterDays Int?
  recurrenceStartDate DateTime?
  recurrenceNextDate  DateTime?
  plannedBy        String?
  plannedAt        DateTime?
  isManualOverride Boolean  @default(false)
  overrideBy       String?
  overrideReason   String?
  overriddenAt     DateTime?
  sequenceNo       Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  account          Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, weekStartDate])
  @@index([salesmanId, weekStartDate])
  @@index([pincode, weekStartDate])
  @@index([salesmanId, pincode, weekStartDate, sequenceNo])
  @@index([salesmanId, recurrenceNextDate])
}

model TelecallerCallLog {
  id             String    @id @default(cuid())
  accountId      String
  telecallerId   String
  calledAt       DateTime  @default(now())
  durationSec    Int?
  status         String
  notes          String?
  recordingUrl   String?
  nextFollowupAt DateTime?
  followupNotes  String?
  account        Account   @relation(fields: [accountId], references: [id])
  telecaller     User      @relation(fields: [telecallerId], references: [id])

  @@index([telecallerId, calledAt])
  @@index([accountId, calledAt])
  @@index([nextFollowupAt])
  @@index([status])
}

/// Mapping of pincodes and days to telecallers.
/// Used so Tele Admin can assign which telecaller owns which pincode on which day.
model TelecallerPincodeAssignment {
  id           String   @id @default(cuid())
  telecallerId String
  pincode      String
  /// 0 = all days, 1 = Monday .. 7 = Sunday
  dayOfWeek    Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  telecaller   User     @relation("TelecallerPincodeAssignments", fields: [telecallerId], references: [id])

  @@index([telecallerId])
  @@index([pincode, dayOfWeek])
}

model SalaryInformation {
  id               String    @id @default(cuid())
  employeeId       String    @unique
  basicSalary      Float
  hra              Float?    @default(0)
  travelAllowance  Float?    @default(0)
  dailyAllowance   Float?    @default(0)
  medicalAllowance Float?    @default(0)
  specialAllowance Float?    @default(0)
  otherAllowances  Float?    @default(0)
  providentFund    Float?    @default(0)
  professionalTax  Float?    @default(0)
  incomeTax        Float?    @default(0)
  otherDeductions  Float?    @default(0)
  effectiveFrom    DateTime
  effectiveTo      DateTime?
  currency         String    @default("INR")
  paymentFrequency String    @default("Monthly")
  bankName         String?
  accountNumber    String?
  ifscCode         String?
  panNumber        String?
  remarks          String?
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  employee         User      @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([effectiveFrom])
  @@index([isActive])
}

model Expense {
  id              String    @id @default(cuid())
  employeeId      String
  expenseType     String
  amount          Float
  expenseDate     DateTime
  description     String?
  billNumber      String?
  attachmentUrl   String?
  status          String    @default("Pending")
  approvedBy      String?
  approvedAt      DateTime?
  rejectionReason String?
  paidAt          DateTime?
  remarks         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  approver        User?     @relation("ApprovedExpenses", fields: [approvedBy], references: [id])
  employee        User      @relation("EmployeeExpenses", fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
  @@index([expenseDate])
  @@index([expenseType])
  @@index([approvedBy], map: "Expense_approvedBy_fkey")
}

model TaskAssignment {
  id              String   @id @default(cuid())
  salesmanId      String
  salesmanName    String
  pincode         String
  country         String?
  state           String?
  district        String?
  city            String?
  areas           Json?
  businessTypes   Json?
  totalBusinesses Int?     @default(0)
  assignedDate    DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([salesmanId])
  @@index([pincode])
  @@index([assignedDate])
}

model Shop {
  id              String    @id @default(cuid())
  placeId         String?   @unique
  name            String
  businessType    String
  address         String?
  pincode         String
  area            String?
  city            String?
  state           String?
  country         String?
  latitude        Float?
  longitude       Float?
  phoneNumber     String?
  rating          Float?
  stage           String    @default("new")
  assignedTo      String?
  notes           String?
  lastContactDate DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([pincode])
  @@index([businessType])
  @@index([stage])
  @@index([assignedTo])
  @@index([area])
}

model Attendance {
  id                      String                  @id @default(cuid())
  employeeId              String
  employeeName            String
  date                    DateTime                @default(now())
  punchInTime             DateTime
  punchInLatitude         Float
  punchInLongitude        Float
  punchInPhoto            String?                 @db.LongText
  punchInAddress          String?
  bikeKmStart             String?
  punchOutTime            DateTime?
  punchOutLatitude        Float?
  punchOutLongitude       Float?
  punchOutPhoto           String?                 @db.LongText
  punchOutAddress         String?
  bikeKmEnd               String?
  totalWorkHours          Float?
  totalDistanceKm         Float?
  status                  String                  @default("active")
  isLatePunchIn           Boolean                 @default(false)
  lateApprovalId          String?
  approvalCode            String?
  isEarlyPunchOut         Boolean                 @default(false)
  earlyPunchOutApprovalId String?
  earlyPunchOutCode       String?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  trackingPoints          SalesmanTrackingPoint[] @relation("AttendanceTrackingPoints")

  @@index([employeeId])
  @@index([date])
  @@index([status])
  @@index([punchInTime])
  @@index([isLatePunchIn])
}

model SalesmanTrackingPoint {
  id            String     @id @default(cuid())
  clientPointId String?    @unique
  employeeId    String
  attendanceId  String
  latitude      Float
  longitude     Float
  speed         Float?
  accuracy      Float?
  recordedAt    DateTime   @default(now())
  attendance    Attendance @relation("AttendanceTrackingPoints", fields: [attendanceId], references: [id], onDelete: Cascade)
  employee      User       @relation("EmployeeTrackingPoints", fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([attendanceId])
  @@index([recordedAt])
  @@index([employeeId, attendanceId, recordedAt])
}

model AreaAssignment {
  id              String   @id @default(cuid())
  salesmanId      String
  pinCode         String
  country         String
  state           String
  district        String
  city            String
  areas           Json?
  businessTypes   Json?
  assignedDate    DateTime @default(now())
  totalBusinesses Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  salesman        User     @relation(fields: [salesmanId], references: [id], onDelete: Cascade)

  @@index([salesmanId])
  @@index([pinCode])
  @@index([city, district])
}

model Notification {
  id           String    @id @default(cuid())
  title        String
  message      String
  type         String
  priority     String    @default("normal")
  targetRole   String?
  targetUserId String?
  data         Json?
  isRead       Boolean   @default(false)
  readAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  targetUser   User?     @relation(fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([targetRole])
  @@index([targetUserId])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
}

model LatePunchApproval {
  id            String    @id @default(cuid())
  employeeId    String
  employeeName  String
  requestDate   DateTime  @default(now())
  punchInDate   DateTime
  reason        String
  status        String    @default("PENDING")
  approvedBy    String?
  approvedAt    DateTime?
  adminRemarks  String?
  approvalCode  String?
  codeExpiresAt DateTime?
  codeUsed      Boolean   @default(false)
  codeUsedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  approver      User?     @relation("AdminLateApprovals", fields: [approvedBy], references: [id])
  employee      User      @relation("EmployeeLateApprovals", fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
  @@index([requestDate])
  @@index([approvalCode])
  @@index([approvedBy], map: "LatePunchApproval_approvedBy_fkey")
}

model EarlyPunchOutApproval {
  id            String    @id @default(cuid())
  employeeId    String
  employeeName  String
  attendanceId  String
  requestDate   DateTime  @default(now())
  punchOutDate  DateTime
  reason        String
  status        String    @default("PENDING")
  approvedBy    String?
  approvedAt    DateTime?
  adminRemarks  String?
  approvalCode  String?
  codeExpiresAt DateTime?
  codeUsed      Boolean   @default(false)
  codeUsedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  approver      User?     @relation("AdminEarlyPunchOutApprovals", fields: [approvedBy], references: [id])
  employee      User      @relation("EmployeeEarlyPunchOutApprovals", fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([attendanceId])
  @@index([status])
  @@index([requestDate])
  @@index([approvalCode])
  @@index([approvedBy], map: "EarlyPunchOutApproval_approvedBy_fkey")
}

model Leave {
  id              String    @id @default(cuid())
  employeeId      String
  employeeName    String
  leaveType       String
  startDate       DateTime
  endDate         DateTime
  numberOfDays    Int
  reason          String?
  status          String    @default("PENDING")
  requestedAt     DateTime  @default(now())
  approvedBy      String?
  approvedAt      DateTime?
  rejectionReason String?
  adminRemarks    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  approver        User?     @relation("ApprovedLeaves", fields: [approvedBy], references: [id])
  employee        User      @relation("EmployeeLeaves", fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@index([leaveType])
  @@index([requestedAt])
  @@index([approvedBy], map: "Leave_approvedBy_fkey")
}

model LeaveBalance {
  id               String   @id @default(cuid())
  employeeId       String   @unique
  year             Int
  sickLeaves       Int      @default(12)
  casualLeaves     Int      @default(10)
  earnedLeaves     Int      @default(20)
  usedSickLeaves   Int      @default(0)
  usedCasualLeaves Int      @default(0)
  usedEarnedLeaves Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  employee         User     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([year])
}

model WeeklyBeatPlan {
  id            String          @id @default(cuid())
  salesmanId    String
  salesmanName  String
  weekStartDate DateTime
  weekEndDate   DateTime
  pincodes      Json?
  totalAreas    Int             @default(0)
  status        String          @default("DRAFT")
  generatedBy   String?
  approvedBy    String?
  approvedAt    DateTime?
  lockedBy      String?
  lockedAt      DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  dailyPlans    DailyBeatPlan[]
  approver      User?           @relation("ApprovedBeatPlans", fields: [approvedBy], references: [id])
  generator     User?           @relation("GeneratedBeatPlans", fields: [generatedBy], references: [id])
  locker        User?           @relation("LockedBeatPlans", fields: [lockedBy], references: [id])
  salesman      User            @relation("SalesmanBeatPlans", fields: [salesmanId], references: [id], onDelete: Cascade)

  @@unique([salesmanId, weekStartDate])
  @@index([salesmanId])
  @@index([weekStartDate])
  @@index([status])
  @@index([generatedBy])
  @@index([approvedBy], map: "WeeklyBeatPlan_approvedBy_fkey")
  @@index([lockedBy], map: "WeeklyBeatPlan_lockedBy_fkey")
}

model DailyBeatPlan {
  id              String           @id @default(cuid())
  weeklyBeatId    String
  dayOfWeek       Int
  dayDate         DateTime
  assignedAreas   Json?
  plannedVisits   Int              @default(0)
  actualVisits    Int              @default(0)
  status          String           @default("PLANNED")
  completedAt     DateTime?
  carriedFromDate DateTime?
  carriedToDate   DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  beatCompletions BeatCompletion[]
  weeklyBeat      WeeklyBeatPlan   @relation(fields: [weeklyBeatId], references: [id], onDelete: Cascade)

  @@unique([weeklyBeatId, dayOfWeek])
  @@index([weeklyBeatId])
  @@index([dayOfWeek])
  @@index([dayDate])
  @@index([status])
}

model BeatCompletion {
  id              String        @id @default(cuid())
  dailyBeatId     String
  salesmanId      String
  areaName        String
  accountsVisited Int           @default(0)
  completedAt     DateTime      @default(now())
  latitude        Float?
  longitude       Float?
  notes           String?
  isVerified      Boolean       @default(false)
  verifiedBy      String?
  verifiedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  dailyBeat       DailyBeatPlan @relation(fields: [dailyBeatId], references: [id], onDelete: Cascade)
  salesman        User          @relation("CompletedBeats", fields: [salesmanId], references: [id], onDelete: Cascade)
  verifier        User?         @relation("VerifiedBeats", fields: [verifiedBy], references: [id])

  @@index([dailyBeatId])
  @@index([salesmanId])
  @@index([completedAt])
  @@index([areaName])
  @@index([verifiedBy], map: "BeatCompletion_verifiedBy_fkey")
}
